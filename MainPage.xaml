<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="how_to_train_your_nailong.MainPage"
    Background="Black"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:how_to_train_your_nailong"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="Black">

        <!-- Layer 0: Nailong video, full-bleed letterboxed on black. -->
        <MediaPlayerElement x:Name="VideoPlayer"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Stretch="Uniform"
                            AreTransportControlsEnabled="False"
                            Background="Transparent" />

        <!-- Layer 1: centered overlay text (countdown / hints / result).
             IsHitTestVisible=False so clicks pass through to the controls below. -->
        <Border x:Name="OverlayBackdrop"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#99000000"
                CornerRadius="16"
                Padding="32,18"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <TextBlock x:Name="OverlayText"
                       Foreground="White"
                       FontSize="56"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Text="" />
        </Border>

        <!-- Layer 2: bottom control bar. -->
        <StackPanel x:Name="ControlBar"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Spacing="12"
                    Margin="0,0,0,28">
            <ComboBox x:Name="DifficultyCombo"
                      Width="100"
                      SelectedIndex="1"
                      SelectionChanged="DifficultyCombo_SelectionChanged">
                <ComboBoxItem>简单</ComboBoxItem>
                <ComboBoxItem>普通</ComboBoxItem>
                <ComboBoxItem>困难</ComboBoxItem>
            </ComboBox>
            <Button x:Name="StartButton"
                    Content="开始挑战"
                    Width="140"
                    Click="StartButton_Click" />
            <Button x:Name="ResetButton"
                    Content="重置"
                    Width="80"
                    Click="ResetButton_Click" />
        </StackPanel>

    </Grid>
</Page>
